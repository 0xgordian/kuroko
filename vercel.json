{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "devCommand": "npm run dev",
  "env": {
    "NEXT_PUBLIC_AOMI_API_KEY": "@kuroko-aomi-api-key",
    "NEXT_PUBLIC_PARA_API_KEY": "@kuroko-para-api-key",
    "NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID": "@kuroko-walletconnect-project-id",
    "NEXT_PUBLIC_POSTHOG_KEY": "@kuroko-posthog-key",
    "NEXT_PUBLIC_SENTRY_DSN": "@kuroko-sentry-dsn",
    "UPSTASH_REDIS_REST_URL": "@kuroko-upstash-redis-url",
    "UPSTASH_REDIS_REST_TOKEN": "@kuroko-upstash-redis-token",
    "KV_REST_API_URL": "@kuroko-kv-rest-api-url",
    "KV_REST_API_TOKEN": "@kuroko-kv-rest-api-token"
  },
  "regions": ["iad1"],
  "functions": {
    "app/api/aomi/**": {
      "maxDuration": 60
    },
    "app/api/markets/**": {
      "maxDuration": 30
    },
    "app/api/clob/**": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}