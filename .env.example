# ============================================================
# Kuroko — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# The app works without credentials in paper-trade mode.
# ============================================================

# --- aomi Backend ---
# The aomi backend URL — use https://api.aomi.dev for production
NEXT_PUBLIC_BACKEND_URL=https://api.aomi.dev

# Optional aomi API key — enables live intent routing through the assistant backend
NEXT_PUBLIC_AOMI_API_KEY=your_aomi_api_key_here

# Optional app id for the aomi assistant backend (defaults to "default")
NEXT_PUBLIC_AOMI_APP_ID=default

# --- Wallet Connect ---
# Required for Para-based wallet connect (Google, Twitter, Discord, email login)
# Get from https://developer.getpara.com
NEXT_PUBLIC_PARA_API_KEY=your_para_api_key_here

# Optional: WalletConnect project ID — removes the warning banner in the Para modal
# Free key at https://cloud.walletconnect.com/sign-in
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# --- Market Discovery Tuning (optional) ---
POLYMARKET_MARKET_LIMIT=200
POLYMARKET_HISTORY_ENRICH_LIMIT=60

# --- Analytics (optional) ---
# PostHog browser analytics — get from https://app.posthog.com → Project Settings → API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here

# Sentry error tracking — get from https://sentry.io → Project → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://your_key@o123456.ingest.us.sentry.io/your_project_id

# --- Rate Limiting (optional, recommended for production) ---
# Upstash Redis — persistent rate limiting across all Vercel instances
# Create a free database at https://upstash.com → choose us-east-1 region, enable eviction
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# --- Shared Market Cache (optional, recommended for production) ---
# Vercel KV — shared market context cache across all serverless instances
# Create at https://vercel.com → your project → Storage → Create KV Store
KV_REST_API_URL=https://your-kv.kv.vercel-storage.com
KV_REST_API_TOKEN=your_kv_token_here
